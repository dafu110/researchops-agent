OPENAI_API_KEY=
DATABASE_URL=postgresql+psycopg://researchops:researchops@postgres:5432/researchops
REDIS_URL=redis://redis:6379/0
VECTOR_BACKEND=pgvector
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=384
RERANKER_PROVIDER=none
AGENT_RUNTIME=auto
OPENAI_AGENT_MODEL=gpt-5-nano
MCP_SERVERS_JSON=[]
MCP_ALLOWED_TOOLS_JSON={}
MCP_TIMEOUT_SECONDS=8
API_KEYS_JSON=[]
LOCAL_USERS_JSON=[]
AUTH_REQUIRED=false
SESSION_TTL_SECONDS=28800
DEFAULT_TENANT_ID=default
SANDBOX_MODE=process
SANDBOX_DOCKER_IMAGE=python:3.12-slim
SANDBOX_MEMORY=128m
SANDBOX_CPUS=0.5
SANDBOX_TIMEOUT_SECONDS=3
SANDBOX_MAX_OUTPUT_CHARS=4000
STORE_BACKEND=auto
URL_FETCH_ALLOWLIST_JSON=[]
URL_FETCH_TIMEOUT_SECONDS=15
URL_FETCH_MAX_REDIRECTS=3
TASK_BACKEND=local
GITHUB_REPO_FILE_MAX_BYTES=80000
GITHUB_REPO_MAX_TEXT_CHARS=500000
APP_ENV=local
LOG_LEVEL=INFO
